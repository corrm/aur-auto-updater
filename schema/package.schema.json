{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "pkgname",
    "type",
    "arch",
    "pkgdesc",
    "upstream",
    "aur_repo"
  ],
  "properties": {
    "pkgname": {
      "type": "string",
      "description": "AUR package name used for PKGBUILD and repository naming."
    },
    "aur_repo": {
      "type": "string",
      "description": "AUR Git repository name (e.g., pkgname or pkgname-bin)."
    },
    "type": {
      "type": "string",
      "description": "Package backend type that determines build logic and required fields.",
      "enum": [
        "appimage",
        "debian",
        "pypi",
        "npm",
        "binary"
      ]
    },
    "pkgdesc": {
      "type": "string",
      "description": "Short description shown in AUR metadata."
    },
    "url": {
      "type": "string",
      "description": "Official project URL."
    },
    "arch": {
      "type": "array",
      "description": "Supported CPU architectures (e.g., x86_64, aarch64).",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "array",
      "description": "License identifiers (SPDX or Arch conventions).",
      "items": {
        "type": "string"
      }
    },
    "depends": {
      "type": "array",
      "description": "Runtime dependencies for the package.",
      "items": {
        "type": "string"
      }
    },
    "makedepends": {
      "type": "array",
      "description": "Build-time dependencies required during PKGBUILD execution.",
      "items": {
        "type": "string"
      }
    },
    "options": {
      "type": "array",
      "description": "AUR/PKGBUILD options flags (e.g., !strip, !debug).",
      "items": {
        "type": "string"
      }
    },
    "conflicts": {
      "type": "array",
      "description": "Package names that this package conflicts with.",
      "items": {
        "type": "string"
      }
    },
    "upstream": {
      "type": "object",
      "description": "Upstream source definition used to fetch releases or artifacts.",
      "required": [
        "provider"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "description": "Upstream provider type used for version resolution.",
          "enum": [
            "github",
            "url",
            "pypi",
            "npm"
          ]
        },
        "repo": {
          "type": "string",
          "description": "Repository identifier (for GitHub provider: owner/repo)."
        },
        "url": {
          "type": "string",
          "description": "Direct URL used when provider is url."
        },
        "asset_regex": {
          "type": "string",
          "description": "Regex used to match release assets from upstream distributions."
        },
        "extract": {
          "type": "string",
          "enum": [
            "none",
            "tar",
            "zip"
          ],
          "default": "none",
          "description": "Extraction method for compressed downloads. tar extracts .tar.gz/.tar.bz2/.tar.xz, zip extracts .zip archives. none keeps the archive as-is."
        },
        "pypi_name": {
          "type": "string",
          "description": "PyPI package name (when provider is pypi). May differ from pkgname."
        },
        "npm_name": {
          "type": "string",
          "description": "npm package name (when provider is npm). May differ from pkgname."
        },
        "arch_map": {
          "type": "object",
          "description": "Mapping from Arch architecture names to GitHub asset architecture names. E.g., {\"x86_64\": \"amd64\", \"aarch64\": \"arm64\"}.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "appimage": {
      "type": "object",
      "description": "AppImage-specific packaging configuration.",
      "properties": {
        "appimage_name": {
          "type": "string",
          "description": "Filename template of the AppImage artifact. May include ${pkgver}."
        },
        "binary_name": {
          "type": "string",
          "description": "Executable name exposed in /usr/bin symlink wrapper."
        },
        "desktop": {
          "type": "boolean",
          "description": "Whether to install a .desktop file for desktop integration."
        },
        "icons": {
          "type": "boolean",
          "description": "Whether to install application icons."
        }
      }
    },
    "binary": {
      "type": "object",
      "description": "Binary package configuration for extracted executables.",
      "properties": {
        "binary_name": {
          "type": "string",
          "description": "Executable name to install in /usr/bin."
        }
      }
    },
    "debian": {
      "type": "object",
      "description": "Debian package extraction and versioning configuration.",
      "properties": {
        "deb_version": {
          "type": "string",
          "description": "Upstream Debian package version selector (or override version strategy)."
        },
        "extract_method": {
          "type": "string",
          "description": "Extraction backend used for .deb unpacking.",
          "enum": [
            "ar",
            "dpkg",
            "bsdtar"
          ]
        }
      }
    },
    "pypi": {
      "type": "object",
      "description": "PyPI-specific packaging configuration.",
      "properties": {
        "package_manager": {
          "type": "string",
          "description": "Package manager to use for installation.",
          "enum": [
            "pip",
            "uv"
          ],
          "default": "pip"
        },
        "build_backend": {
          "type": "string",
          "description": "Build backend for PEP 517 builds.",
          "enum": [
            "pep517",
            "setuptools"
          ],
          "default": "pep517"
        }
      }
    },
    "npm": {
      "type": "object",
      "description": "npm-specific packaging configuration.",
      "properties": {
        "package_manager": {
          "type": "string",
          "description": "Package manager to use for installation.",
          "enum": [
            "npm",
            "bun"
          ],
          "default": "npm"
        },
        "global_bin": {
          "type": "string",
          "description": "The name of the global binary executable exposed in /usr/bin."
        }
      }
    },
    "provides": {
      "type": "array",
      "description": "Package names this package provides (virtual packages).",
      "items": {
        "type": "string"
      }
    },
    "systemd_service": {
      "type": "string",
      "description": "Systemd service file to install (relative to source archive)."
    },
    "install_files": {
      "type": "array",
      "description": "Files to install with custom destinations and modes.",
      "items": {
        "type": "object",
        "required": [
          "source",
          "dest",
          "mode"
        ],
        "properties": {
          "source": {
            "type": "string",
            "description": "Source file path (relative to archive root)."
          },
          "dest": {
            "type": "string",
            "description": "Destination path (e.g., /usr/share/licenses/)."
          },
          "mode": {
            "type": "string",
            "enum": [
              "644",
              "755"
            ],
            "description": "File permissions. 644 for files, 755 for executables."
          }
        }
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "type": {
          "const": "appimage"
        }
      },
      "required": [
        "appimage"
      ]
    },
    {
      "properties": {
        "type": {
          "const": "debian"
        }
      }
    },
    {
      "properties": {
        "type": {
          "const": "pypi"
        }
      }
    },
    {
      "properties": {
        "type": {
          "const": "npm"
        }
      }
    },
    {
      "properties": {
        "type": {
          "const": "binary"
        }
      },
      "required": [
        "binary"
      ]
    }
  ]
}