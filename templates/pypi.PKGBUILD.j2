pkgname={{ pkgname }}
pkgver={{ pkgver }}
pkgrel=1
pkgdesc="{{ pkgdesc }}"
arch=({{ arch | join(' ') }})
url="{{ url }}"
license=({{ license | join(' ') }})

{%- set pm = package_manager | default('pip') %}
{%- if pm == 'uv' %}
{%- set builtin_deps = ['python'] %}
{%- set makedepends_list = makedepends + ['uv'] %}
{%- else %}
{%- set builtin_deps = ['python', 'python-pip'] %}
{%- set makedepends_list = makedepends %}
{%- endif %}
{%- if makedepends_list %}
makedepends=({% for d in makedepends_list %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if optdepends %}
optdepends=({% for d in optdepends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}

{%- set all_depends = (depends or []) + builtin_deps %}
depends=({% for d in all_depends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- if options %}
options=({{ options | join(' ') }})
{%- endif %}
{%- if conflicts %}
conflicts=({% for d in conflicts %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if provides %}
provides=({{ provides | join(' ') }})
{%- endif %}

source=("{{ download_url }}")
sha256sums=('{{ sha256 }}')

build() {
    cd "${srcdir}/{{ _pypi_name }}-${pkgver}"
    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/{{ _pypi_name }}-${pkgver}"
    python -m installer --destdir="${pkgdir}" --prefix=/usr dist/*.whl
{%- if install_files %}
{%- for file in install_files %}
    install -Dm{{ file.mode }} "{{ file.source }}" "${pkgdir}{{ file.dest }}"
{%- endfor %}
{%- endif %}
{%- if systemd_service %}
    install -Dm644 "{{ systemd_service }}" "${pkgdir}/usr/lib/systemd/user/{{ systemd_service }}"
{%- endif %}
{%- if desktop %}
    if [ -d "${pkgdir}/usr/share/applications" ]; then
        find "${pkgdir}/usr/share/applications" -name "*.desktop" -exec sed -i "s|Exec=.*|Exec={{ binary_name }} %U|" {} \;
    fi
{%- endif %}
{%- if icons %}
    if [ -d "${pkgdir}/usr/share/icons" ]; then
        find "${pkgdir}/usr/share/icons" -type d -exec chmod 755 {} +
        find "${pkgdir}/usr/share/icons" -type f -exec chmod 644 {} +
    fi
{%- endif %}
}