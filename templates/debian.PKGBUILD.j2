pkgname={{ pkgname }}
pkgver={{ pkgver }}
pkgrel=1
pkgdesc="{{ pkgdesc }}"
arch=({{ arch | join(' ') }})
url="{{ url }}"
license=({{ license | join(' ') }})

depends=({{ depends | join(' ') }})
makedepends=({{ makedepends | join(' ') }})
options=({{ options | join(' ') }})

_debver="{{ deb_version }}"

source=("${pkgname}-${_debver}.deb::{{ download_url }}")
sha256sums=('{{ sha256 }}')

prepare() {
    command -v ar >/dev/null 2>&1 || exit 1
    command -v tar >/dev/null 2>&1 || exit 1

    mkdir -p "${srcdir}/deb"
    cd "${srcdir}/deb"

    ar x "../${pkgname}-${_debver}.deb"
}

package() {
    cd "${srcdir}/deb"

    if [[ ! -f data.tar.* ]]; then
        echo "Missing data.tar"
        exit 1
    fi

    tar -xf data.tar.* -C "${pkgdir}"
}