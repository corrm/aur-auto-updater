pkgname={{ pkgname }}
pkgver={{ pkgver }}
pkgrel=1
pkgdesc="{{ pkgdesc }}"
arch=({{ arch | join(' ') }})
url="{{ url }}"
license=({{ license | join(' ') }})

depends=({% for d in depends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- set method = extract_method | default('ar') %}
{%- if method == 'dpkg' %}
{%- set makedepends_list = makedepends + ['dpkg'] %}
{%- else %}
{%- set makedepends_list = makedepends %}
{%- endif %}
{%- if makedepends_list %}
makedepends=({% for d in makedepends_list %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if options %}
options=({{ options | join(' ') }})
{%- endif %}
{%- if conflicts %}
conflicts=({% for d in conflicts %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if provides %}
provides=({{ provides | join(' ') }})
{%- endif %}

source=("{{ download_url }}")
sha256sums=('{{ sha256 }}')

_debfile="$(basename '{{ download_url }}')"

prepare() {
    mkdir -p "${srcdir}/deb_contents"
    cd "${srcdir}/deb_contents"
{%- if method == 'ar' %}
    command -v ar >/dev/null 2>&1 || { echo "Error: 'ar' is required but not found."; exit 1; }
    ar x "../${_debfile}"
{%- elif method == 'dpkg' %}
    command -v dpkg-deb >/dev/null 2>&1 || { echo "Error: 'dpkg-deb' is required but not found."; exit 1; }
    dpkg-deb -x "../${_debfile}" .
{%- elif method == 'bsdtar' %}
    command -v bsdtar >/dev/null 2>&1 || { echo "Error: 'bsdtar' is required but not found."; exit 1; }
    bsdtar -xf "../${_debfile}"
{%- endif %}
}

package() {
    cd "${srcdir}/deb_contents"
    if [[ ! -f data.tar.* ]]; then
        echo "Error: data.tar.* not found in the Debian package."
        exit 1
    fi
    tar -xf data.tar.* -C "${pkgdir}"
    # Install additional files from deb_contents (e.g., LICENSE from .deb)
{%- if install_files %}
{%- for file in install_files %}
    install -Dm{{ file.mode }} "{{ file.source }}" "${pkgdir}{{ file.dest }}"
{%- endfor %}
{%- endif %}
}