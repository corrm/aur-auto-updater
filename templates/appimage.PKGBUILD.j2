pkgname={{ pkgname }}
pkgver={{ pkgver }}
pkgrel=1
pkgdesc="{{ pkgdesc }}"
arch=({{ arch | join(' ') }})
url="{{ url }}"
license=({{ license | join(' ') }})

depends=({% for d in depends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- if makedepends %}
makedepends=({% for d in makedepends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if optdepends %}
optdepends=({% for d in optdepends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if options %}
options=({{ options | join(' ') }})
{%- else %}
options=(!strip !debug)
{%- endif %}
{%- if conflicts %}
conflicts=({% for d in conflicts %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if provides %}
provides=({{ provides | join(' ') }})
{%- endif %}

_appimage="{{ appimage_name }}"
source=("${_appimage}::{{ download_url }}")
sha256sums=('{{ sha256 }}')
noextract=("${_appimage}")

prepare() {
    chmod +x "${_appimage}"
    ./"${_appimage}" --appimage-extract
}

package() {
    install -Dm755 "${srcdir}/${_appimage}" \
        "${pkgdir}/opt/${pkgname}/${_appimage}"

    install -dm755 "${pkgdir}/usr/bin"
    ln -s "/opt/${pkgname}/${_appimage}" "${pkgdir}/usr/bin/{{ binary_name }}"

    # Install extra files from srcdir (e.g., LICENSE alongside AppImage)
{%- if install_files %}
{%- for file in install_files %}
    install -Dm{{ file.mode }} "${srcdir}/{{ file.source }}" "${pkgdir}{{ file.dest }}"
{%- endfor %}
{%- endif %}

    cd "${srcdir}/squashfs-root"
{%- if desktop %}
    find . -maxdepth 1 -name '*.desktop' -exec \
        install -Dm644 {} "${pkgdir}/usr/share/applications/{{ binary_name }}.desktop" \;

    sed -i "s|Exec=.*|Exec={{ binary_name }} %U|" \
        "${pkgdir}/usr/share/applications/{{ binary_name }}.desktop"
    sed -i "s|Icon=.*|Icon={{ binary_name }}|" \
        "${pkgdir}/usr/share/applications/{{ binary_name }}.desktop"
{%- endif %}
{%- if icons %}
    if [ -d usr/share/icons ]; then
        # Install icon files directly with binary_name — no cp+mv rename needed
        find usr/share/icons -type f \( -name '*.png' -o -name '*.svg' \) | while read -r icon; do
            relpath="${icon#usr/share/icons/}"
            dir="${pkgdir}/usr/share/icons/$(dirname "$relpath")"
            base=$(basename "$icon")
            ext="${base##*.}"
            install -Dm644 "$icon" "${dir}/{{ binary_name }}.${ext}"
        done
        # Copy non-icon files (index.theme, etc.) as-is
        find usr/share/icons -type f ! \( -name '*.png' -o -name '*.svg' \) | while read -r f; do
            relpath="${f#usr/share/icons/}"
            install -Dm644 "$f" "${pkgdir}/usr/share/icons/${relpath}"
        done
    fi

    # Install root-level icons to pixmaps (first matching png or svg)
    for f in *.png *.svg; do
        [ -f "$f" ] || continue
        ext="${f##*.}"
        install -Dm644 "$f" "${pkgdir}/usr/share/pixmaps/{{ binary_name }}.${ext}"
        break
    done
{%- endif %}
}