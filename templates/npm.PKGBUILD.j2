pkgname={{ pkgname }}
pkgver={{ pkgver }}
pkgrel={{ pkgrel | default(1) }}
pkgdesc="{{ pkgdesc }}"
arch=({{ arch | join(' ') }})
url="{{ url }}"
license=({{ license | join(' ') }})

{%- set pm = package_manager | default('npm') %}
{%- if pm == 'bun' %}
{%- set builtin_deps = ['bun'] %}
{%- set makedepends_list = makedepends + ['bun', 'jq', 'findutils'] %}
{%- else %}
{%- set builtin_deps = ['nodejs', 'npm'] %}
{%- set makedepends_list = makedepends + ['npm', 'jq', 'findutils'] %}
{%- endif %}
{%- if makedepends_list %}
makedepends=({% for d in makedepends_list %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if optdepends %}
optdepends=({% for d in optdepends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}

{%- set user_deps = depends or [] %}
{%- set all_depends = (user_deps + builtin_deps) | unique %}
depends=({% for d in all_depends %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- if options %}
options=({{ options | join(' ') }})
{%- endif %}
{%- if conflicts %}
conflicts=({% for d in conflicts %}"{{ d }}"{% if not loop.last %} {% endif %}{% endfor %})
{%- endif %}
{%- if provides %}
provides=({{ provides | join(' ') }})
{%- endif %}

{%- set _npm_name = npm_name if npm_name else pkgname %}
_npm_name="{{ _npm_name }}"
source=("{{ download_url }}")
sha256sums=('{{ sha256 }}')

prepare() {
    mkdir -p "${srcdir}/npm-cache"
}

package() {
    cd "${srcdir}"
{%- if pm == 'bun' %}
    bun install --cache "${srcdir}/npm-cache" --global --prefix "${pkgdir}/usr" "{{ _npm_name }}-${pkgver}.tgz"
{%- else %}
    npm install -g --prefix "${pkgdir}/usr" --cache "${srcdir}/npm-cache" "{{ _npm_name }}-${pkgver}.tgz"
{%- endif %}

    # Fix permissions that sometimes break module resolution
    find "${pkgdir}/usr/lib/node_modules" -type d -exec chmod 755 {} +

    # Fix package.json files
    find "${pkgdir}" -name "package.json" -print0 | xargs -r -0 sed -i '/_where/d'

    local tmppackage="$(mktemp)"
    local pkgjson
    for pkgjson in $(find "${pkgdir}" -type f -name "package.json"); do
        jq '.|=with_entries(select(.key|test("_.+")|not))' "$pkgjson" > "$tmppackage"
        mv "$tmppackage" "$pkgjson"
        chmod 644 "$pkgjson"
    done

    find "${pkgdir}" -type f -name "package.json" | while read -r pkgjson; do
        local tmppackage="$(mktemp)"
        jq 'del(.man)' "$pkgjson" > "$tmppackage"
        mv "$tmppackage" "$pkgjson"
        chmod 644 "$pkgjson"
    done
{%- if install_files %}
{%- for file in install_files %}
    install -Dm{{ file.mode }} "${srcdir}/{{ file.source }}" "${pkgdir}{{ file.dest }}"
{%- endfor %}
{%- endif %}
{%- if systemd_service %}
    install -Dm644 "${srcdir}/{{ systemd_service }}" "${pkgdir}/usr/lib/systemd/user/{{ systemd_service }}"
{%- endif %}
{%- if desktop %}
    if [ -d "${pkgdir}/usr/share/applications" ]; then
        find "${pkgdir}/usr/share/applications" -name "*.desktop" -exec sed -i "s|Exec=.*|Exec={{ binary_name }} %U|" {} \;
    fi
{%- endif %}
{%- if icons %}
    if [ -d "${pkgdir}/usr/share/icons" ]; then
        find "${pkgdir}/usr/share/icons" -type d -exec chmod 755 {} +
        find "${pkgdir}/usr/share/icons" -type f -exec chmod 644 {} +
    fi
{%- endif %}
}